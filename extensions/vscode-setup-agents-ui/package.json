{
  "name": "setup-agents-ui",
  "displayName": "Salesforce Setup Agents",
  "description": "Configure AI coding assistants for Salesforce projects — profiles, rules, MCP integrations, and guided setup.",
  "version": "0.3.0",
  "publisher": "jterrats",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jterrats/setup-agents",
    "directory": "extensions/vscode-setup-agents-ui"
  },
  "homepage": "https://jterrats.github.io/setup-agents/extension.html",
  "bugs": {
    "url": "https://github.com/jterrats/setup-agents/issues"
  },
  "keywords": [
    "salesforce",
    "ai",
    "agents",
    "cursor",
    "copilot",
    "claude",
    "mcp",
    "profiles",
    "setup"
  ],
  "galleryBanner": {
    "color": "#4f63d9",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:setupAgentsUi.sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "setupAgentsUi.open",
        "title": "Setup Agents: Open UI"
      },
      {
        "command": "setupAgentsUi.importRulesFromUrl",
        "title": "Setup Agents: Import Rules From URL"
      },
      {
        "command": "setupAgentsUi.importRulesFromFile",
        "title": "Setup Agents: Import Rules From File"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "setupAgentsUi",
          "title": "Salesforce Setup Agents",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "setupAgentsUi": [
        {
          "id": "setupAgentsUi.sidebar",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "clean": "rm -rf out",
    "lint": "eslint src --ext .ts",
    "test": "node --test out/test/ruleManagementService.test.js",
    "test:e2e": "npx playwright test",
    "demo:record": "npx playwright test --config playwright.demo.config.ts",
    "demo:gifs": "bash scripts/webm-to-gif.sh",
    "demo": "npm run demo:record && npm run demo:gifs",
    "test:e2e:vscode": "tsc -p tsconfig.e2e.json && node out/test/e2e/runTest.js",
    "pretest": "npm run build",
    "package": "vsce package"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.2",
    "eslint": "^8.57.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.5.4"
  }
}
